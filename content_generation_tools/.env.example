# OpenAI API Key (Required for image generation and text processing)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: If you use a proxy or API gateway for OpenAI
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Claude API Key (if you use Claude for text processing instead of OpenAI/DeepSeek)
# ANTHROPIC_API_KEY=sk-ant-your-claude-key-here

# Content Studio Writer/Fixer (default for media + commercial PPT)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Content Studio Fact Reviewer (cross-model gate)
KIMI_API_KEY=sk-your-kimi-key-here
MOONSHOT_API_KEY=sk-your-kimi-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Qwen fallback writer/reviewer (DashScope OpenAI-compatible)
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

ZHIPU_API_KEY=your-zhipu-api-key-here

# Volcengine — 控制台「API Key 管理」完整密钥（api-key-20260607... 那条）
# TTS 豆包语音：请求头 X-Api-Key + X-Api-Resource-Id: seed-tts-2.0
VOLC_SPEECH_API_KEY=your-volc-api-key-here
# Seedream 画图：Authorization Bearer（可能与上同值，或单独 ark- 串，以控制台为准）
ARK_API_KEY=your-ark-or-volc-api-key-here
# ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3/images/generations
# 勿用「默认体验中心」UUID；勿提交 .env

# US Finance XHS — voice broadcast (Doubao TTS + MP4). Default off (cost).
# FINANCE_XHS_VOICE=1
# FINANCE_XHS_VOICE_VIDEO=1
# FINANCE_XHS_VOICE_SPEAKER=zh_female_shuangkuaisisi_uranus_bigtts
