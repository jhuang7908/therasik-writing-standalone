# Creative Studio — 环境变量
# 复制此文件为 .env，填入真实 key（本地开发用）
# 线上部署（Render）在 Dashboard 的 Environment 页面填写

# 必填：至少填一个 LLM key
DEEPSEEK_API_KEY=sk-xxx       # deepseek.com → API Keys
OPENAI_API_KEY=sk-xxx         # platform.openai.com → API Keys
ANTHROPIC_API_KEY=sk-xxx      # anthropic.com → API Keys
KIMI_API_KEY=sk-xxx           # platform.moonshot.cn → API Keys

# 可选：自动生成安全 token（Render 会自动 generateValue）
SECRET_KEY=change-me-in-production
