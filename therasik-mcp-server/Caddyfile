# Caddyfile — automatic HTTPS, no certbot needed
# Replace YOUR_DOMAIN with actual domain (e.g. api.insynbio.com)

{
    email admin@insynbio.com
}

YOUR_DOMAIN {
    reverse_proxy engine:8000

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }

    # Rate limit at CDN level (coarse guard, fine-grained in Redis)
    # Requires Caddy with rate_limit module; omit if not available
    # rate_limit {
    #     zone static 50r/m
    # }

    log {
        output file /var/log/caddy/access.log
    }
}
