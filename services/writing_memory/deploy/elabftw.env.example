# Copy to /srv/services/writing_memory/.env (or merge into existing .env)
# Restart: systemctl restart writing-memory

# eLabFTW instance (Module 3)
ELABFTW_BASE_URL=https://lab.insynbio.com
ELABFTW_PUBLIC_URL=https://lab.insynbio.com
ELABFTW_API_TOKEN=your_elabftw_api_key_from_settings

# Optional multi-tenant Lab routing.
# Copy deploy/elabftw_tenants.example.json to a server-only path, edit project/customer
# mappings, and keep customer tokens in env vars (not in git-tracked JSON).
ELABFTW_TENANTS_FILE=/srv/services/writing_memory/lab_tenants.json
ELABFTW_TOKEN_CUSTOMER_A=customer_a_service_account_api_key

# protocols.io public search (Module 3 — https://www.protocols.io/developers)
PROTOCOLSIO_ACCESS_TOKEN=your_protocols_io_client_token
PROTOCOLSIO_WORKSPACE_URI=insynbio

# Platform SMTP (SaaS): sends orders/bookings to the email entered in the Lab UI per customer/group.
# Optional default suggestion in UI when tenant JSON has no lab_manager_email:
# LAB_MANAGER_EMAIL=lab.manager@your-org.org
# Optional per-tenant default in lab_tenants.json: "lab_manager_email": "manager@customer.org"
# LAB_SMTP_HOST=smtp.your-org.org
# LAB_SMTP_PORT=587
# LAB_SMTP_USER=
# LAB_SMTP_PASSWORD=
# LAB_SMTP_FROM=lab-noreply@your-org.org
# LAB_SMTP_TLS=1

# OpenAlex polite pool (Module 5)
OPENALEX_EMAIL=ops@insynbio.com

# USPTO Open Data Portal — structured patent search (Module 6)
# See deploy/USPTO_ODP_API_KEY.md
USPTO_ODP_API_KEY=
