# Copy to .env (never commit .env) and load before running ingest scripts.

NCBI_API_KEY=your_ncbi_api_key_here

NCBI_TOOL=insynbio_writing_memory

NCBI_EMAIL=your_contact_email@example.com



# Week 2+

# ANTHROPIC_API_KEY=sk-proj-FIZAkJzOxYS5OVNxnz8eYt_UzsvSlUbe8ylGWyKmDVCHzm4LIs_tCTpcalkAymEBSKVkyAdPelT3BlbkFJ5JM0wXGKpIMI0oaJAlmysoNXdGsAXeuZ-hK2zsBNHHd3J8kn-BtdRSwRSTYFxYH43LtGa3qqYAY_PG=postgresql://user:pass@localhost:5432/writing_memory



# ---------------------------------------------------------------------------

# LLM provider (SaaS debug vs production)

# ---------------------------------------------------------------------------

# anthropic = default (Claude Sonnet/Haiku routing)

# deepseek  = use DeepSeek API for all Plan/Rewrite/Ask calls (flow testing)

WM_LLM_PROVIDER=anthropic



# DeepSeek (OpenAI-compatible) — only when WM_LLM_PROVIDER=deepseek

# DEEPSEEK_API_KEY=sk-...

# deepseek-chat     = faster, good for pipeline smoke tests

# deepseek-reasoner = "think" mode, slower, more tokens

# DEEPSEEK_MODEL=deepseek-chat

# DEEPSEEK_BASE_URL=https://api.deepseek.com



# Claude model override (when WM_LLM_PROVIDER=anthropic)

# ANTHROPIC_MODEL=claude-sonnet-4-5



# Quota (optional)

# WM_QUOTA_PLAN=20

# WM_QUOTA_DRAFT=40

# WM_QUOTA_POLISH=60

# WM_UNLIMITED_USERS=Admin,admin

