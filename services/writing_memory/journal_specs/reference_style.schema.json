{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://insynbio.com/schemas/writing_memory/reference_style.v0_1.schema.json",
  "title": "ReferenceStyle",
  "description": "Curated reference-formatting rules for one journal. Drives format_reference(paper_row, style_id). Every value carries verification_status and a source_url. Never auto-generated by LLM.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "display_name",
    "in_text_citation",
    "list_order",
    "list_entry"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1.0" },
    "id":             { "type": "string", "pattern": "^[a-z][a-z0-9_]+$" },
    "display_name":   { "type": "string" },
    "based_on":       { "type": ["string","null"], "description": "e.g. Vancouver / AMA 11th / CSE / Harvard" },
    "sourced_from": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url","label"],
        "properties": {
          "url":   { "type": "string", "format": "uri" },
          "label": { "type": "string" },
          "captured_at": { "type": ["string","null"], "format": "date-time" }
        }
      }
    },

    "in_text_citation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode","verification_status"],
      "properties": {
        "mode": {
          "enum": [
            "numbered_parenthetical",
            "numbered_superscript",
            "numbered_bracketed",
            "author_year_parenthetical",
            "author_year_narrative",
            "other"
          ]
        },
        "examples":           { "type": "array", "items": { "type": "string" } },
        "multiple_citations": { "type": ["string","null"], "description": "How to combine, e.g. '(1, 2)' vs '(1-3)'" },
        "verification_status": { "enum": ["verified","unverified","out_of_date"] },
        "source_url":          { "type": ["string","null"], "format": "uri" },
        "notes":               { "type": ["string","null"] }
      }
    },

    "list_order": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode","verification_status"],
      "properties": {
        "mode": { "enum": ["by_appearance","alphabetical_by_author","alphabetical_then_chrono"] },
        "verification_status": { "enum": ["verified","unverified","out_of_date"] },
        "source_url": { "type": ["string","null"], "format": "uri" },
        "notes": { "type": ["string","null"] }
      }
    },

    "list_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "author_list",
        "journal_abbreviation",
        "year_position",
        "title_case",
        "doi_required",
        "url_required",
        "verification_status"
      ],
      "properties": {
        "author_list": {
          "type": "object",
          "additionalProperties": false,
          "required": ["format","et_al_threshold","et_al_keep_first"],
          "properties": {
            "format":            { "enum": ["last_initials","last_firstname","initials_last"] },
            "separator":         { "type": ["string","null"], "description": "e.g. ', ' or '; '" },
            "et_al_threshold":   { "type": ["integer","null"], "minimum": 1 },
            "et_al_keep_first":  { "type": ["integer","null"], "minimum": 1 },
            "final_separator":   { "type": ["string","null"], "description": "e.g. ', and ' vs ', '" }
          }
        },

        "journal_abbreviation": {
          "enum": ["pubmed_nlm_ta","full_title","ams","unspecified"]
        },
        "year_position":  { "enum": ["after_authors","at_end_before_doi","at_end","other"] },
        "title_case":     { "enum": ["sentence_case","title_case","preserve_as_published"] },
        "italicize": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "journal_title": { "type": "boolean" },
            "book_title":    { "type": "boolean" },
            "article_title": { "type": "boolean" }
          }
        },
        "volume_issue_pages_format": {
          "type": ["string","null"],
          "description": "Free-text template, e.g. 'Vol;Iss:Pages' or 'Vol(Iss):Pages'."
        },
        "doi_required":   { "type": "boolean" },
        "doi_format":     { "type": ["string","null"], "description": "e.g. 'doi:10.xxxx/...' vs 'https://doi.org/...'" },
        "url_required":   { "type": "boolean" },
        "preprint_handling": { "type": ["string","null"] },
        "verification_status": { "enum": ["verified","unverified","out_of_date"] },
        "source_url":          { "type": ["string","null"], "format": "uri" },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["raw","rendered"],
            "properties": {
              "raw":      { "type": "object" },
              "rendered": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
