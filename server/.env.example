# Copy to .env and fill in values before running docker compose

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password

# Gemini API (server-side pool — never exposed to clients)
GEMINI_API_KEY=AIza...

# Random 32-char hex used for key hashing
SECRET_SALT=change_me_32char_hex_salt_here00

# Optional: Stripe webhook secret (Phase 3)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: SMTP for key delivery emails (Phase 3)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG....
# SMTP_FROM=noreply@insynbio.com
