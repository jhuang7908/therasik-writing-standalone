+# Ensure the directory is in path
+sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
+from scripts.structure_metrics_humanization import (
+    analyze_structure,
+    StructureMetrics,
+    _get_cdr_residue_indices,
+    KABAT_CDR_VH,
+    KABAT_CDR_VL,
