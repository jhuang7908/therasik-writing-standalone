+"""
+FXY_2C2 — Rebuild SSOT with strict CDR preservation
+===================================================
+Rebuild humanized VH/VL sequences using Kabat insertion-code aware assembly,
+and update `projects/fxy_2c2_Redesign/fxy_2c2_results.json` as the single source of truth.
+
+Non-negotiable invariant:
+  - All 6 CDRs (VH H1/H2/H3 + VL L1/L2/L3) must EXACTLY match the mouse parent,
+    including insertion-code residues (e.g., 30A/52A/etc).
+
+This script:
+  1) Loads mouse sequences from SSOT
+  2) Loads germline V-regions by gene ID from IMGT AA JSON
+  3) Assembles v1 (no BM) and v2 (Vernier BM map) with `assemble_humanized_v()`
+  4) Hard-gates with `verify_cdr_preservation()`
+  5) Updates SSOT sequences + Kabat FR/CDR annotation blocks
+  6) (Optional) Rebuilds PDBs (ABodyBuilder2) and re-runs AbEvaluator for v1/v2
+     to refresh structure/developability/immunogenicity fields used by the report renderer.
+
+Usage:
+  python projects/fxy_2c2_Redesign/rebuild_fxy_2c2_ssot.py --with-structures --with-eval
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import sys
+from dataclasses import asdict
+from datetime import datetime
+from pathlib import Path
+from typing import Any, Dict, Optional, Tuple
+
+SUITE = Path(__file__).resolve().parents[2]
+if str(SUITE) not in sys.path:
+    sys.path.insert(0, str(SUITE))
+
+from core.humanization.kabat_utils import (  # noqa: E402
+    get_kabat_numbering,
+    assemble_humanized_v,
+    verify_cdr_preservation,
+    sorted_keys,
+    CDR_RANGES_VH,
+    CDR_RANGES_VL,
+    VERNIER_KABAT_TO_IMGT_VH,
+    VERNIER_KABAT_TO_IMGT_VL,
+)
+
+
+JH4_FR4 = "WGQGTLVTVSS"
+JK4_FR4 = "FGGGTKLEIK"
+
+
+def _load_json(path: Path) -> Dict[str, Any]:
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def _write_json(path: Path, obj: Dict[str, Any]) -> None:
+    path.write_text(json.dumps(obj, indent=2, ensure_ascii=False), encoding="utf-8")
+
+
+def _load_germline_seq(gene_id: str, chain: str) -> str:
+    """
+    Load V-region AA sequence from IMGT JSON by gene_id.
+    chain: "VH" or "VL" (kappa light).
+    """
+    if chain == "VH":
+        db = SUITE / "data" / "germlines" / "human_ig_aa" / "IGHV_aa.json"
+    else:
+        db = SUITE / "data" / "germlines" / "human_ig_aa" / "IGKV_aa.json"
+    data = _load_json(db)
+    for e in (data.get("entries") or []):
+        if e.get("id") == gene_id:
+            seq = str(e.get("sequence_aa") or "")
+            if not seq:
+                raise ValueError(f"Empty germline sequence for {gene_id} in {db}")
+            return seq
+    raise KeyError(f"Germline gene not found: {gene_id} in {db}")
+
+
+def _span(kd: Dict[Tuple[int, str], str], lo: int, hi: int) -> str:
+    return "".join(kd[k] for k in sorted_keys(kd) if lo <= k[0] <= hi)
+
+
+def _build_kabat_annotation(seq: str, chain: str) -> Dict[str, Any]:
+    kd = get_kabat_numbering(seq)
+    if not kd:
+        raise RuntimeError(f"Kabat numbering failed for {chain} (len={len(seq)})")
+
+    if chain == "VH":
+        fr4_lo = 103
+        regions = [("FR1", 1, 25), ("CDR1", 26, 35), ("FR2", 36, 49),
+                   ("CDR2", 50, 65), ("FR3", 66, 94), ("CDR3", 95, 102)]
+    else:
+        fr4_lo = 98
+        regions = [("FR1", 1, 23), ("CDR1", 24, 34), ("FR2", 35, 49),
+                   ("CDR2", 50, 56), ("FR3", 57, 88), ("CDR3", 89, 97)]
+
+    max_int = max(k[0] for k in kd.keys())
+    fr4_hi = max_int if max_int >= fr4_lo else fr4_lo
+
+    ann = []
+    cdr_lengths = {}
+    for name, lo, hi in regions:
+        s = _span(kd, lo, hi)
+        ann.append({"region": name, "kabat": f"{lo}-{hi}", "seq": s})
+        if name.startswith("CDR"):
+            cdr_lengths[name] = len(s)
+
+    ann.append({"region": "FR4", "kabat": f"{fr4_lo}-{fr4_hi}", "seq": _span(kd, fr4_lo, fr4_hi)})
+
+    return {
+        "sequence": seq,
+        "annotation": ann,
+        "cdr_lengths": cdr_lengths,
+    }
+
+def _compute_pi(vh: str, vl: str) -> Optional[float]:
+    try:
+        from Bio.SeqUtils.ProtParam import ProteinAnalysis  # type: ignore
+        seq = (vh or "") + (vl or "")
+        if not seq:
+            return None
+        return float(ProteinAnalysis(seq).isoelectric_point())
+    except Exception:
+        return None
+
+
+def _in_cdr_kabat(pos: int, chain: str) -> bool:
+    ranges = CDR_RANGES_VH if chain == "VH" else CDR_RANGES_VL
+    return any(lo <= pos <= hi for lo, hi in ranges)
+
+
+def _kabatdict_to_seq(kd: Dict[Tuple[int, str], str]) -> str:
+    return "".join(kd[k] for k in sorted_keys(kd))
+
+
+def _design_v3_pi(
+    v2_vh: str,
+    v2_vl: str,
+    mouse_vh_kd: Dict[Tuple[int, str], str],
+    mouse_vl_kd: Dict[Tuple[int, str], str],
+    target_pi_max: float = 8.5,
+    max_mutations: int = 4,
+) -> Tuple[str, str, list[Dict[str, Any]]]:
+    """
+    Design v3 by lowering pI via FR-only charge reduction mutations.
+    Invariants:
+      - Never mutate Kabat CDR positions
+      - Prefer non-Vernier positions (conservative)
+      - Verify all 6 CDRs exactly match mouse after each accepted change
+    Returns: (v3_vh, v3_vl, mutations_v2_to_v3)
+    """
+    # Candidate Vernier positions (avoid)
+    vh_vernier = set(int(x) for x in VERNIER_KABAT_TO_IMGT_VH.keys())
+    vl_vernier = set(int(x) for x in VERNIER_KABAT_TO_IMGT_VL.keys())
+
+    vh_kd = get_kabat_numbering(v2_vh)
+    vl_kd = get_kabat_numbering(v2_vl)
+    if not vh_kd or not vl_kd:
+        raise RuntimeError("Kabat numbering failed for v2; cannot design v3.")
+
+    base_pi = _compute_pi(v2_vh, v2_vl)
+    if base_pi is None:
+        raise RuntimeError("Unable to compute pI (BioPython missing or bad sequence).")
+
+    muts: list[Dict[str, Any]] = []
+
+    def _candidate_positions(kd: Dict[Tuple[int, str], str], chain: str) -> list[int]:
+        out: list[int] = []
+        vernier = vh_vernier if chain == "VH" else vl_vernier
+        for (pos, ins), aa in kd.items():
+            if ins != "":
+                continue  # only mutate base residue at (pos,"")
+            if aa not in ("K", "R"):
+                continue
+            if _in_cdr_kabat(pos, chain):
+                continue
+            if pos in vernier:
+                continue
+            out.append(pos)
+        return sorted(set(out))
+
+    vh_cands = _candidate_positions(vh_kd, "VH")
+    vl_cands = _candidate_positions(vl_kd, "VL")
+
+    # Greedy: choose the single mutation that reduces pI most each round
+    current_vh_kd = dict(vh_kd)
+    current_vl_kd = dict(vl_kd)
+    current_pi = base_pi
+
+    def _try_mut(chain: str, pos: int, new_aa: str) -> Optional[Tuple[float, str, str]]:
+        nonlocal current_vh_kd, current_vl_kd
+        kd = current_vh_kd if chain == "VH" else current_vl_kd
+        key = (pos, "")
+        old = kd.get(key)
+        if old is None or old == new_aa:
+            return None
+        if old not in ("K", "R"):
+            return None
+
+        kd2 = dict(kd)
+        kd2[key] = new_aa
+
+        if chain == "VH":
+            vh_seq = _kabatdict_to_seq(kd2)
+            vl_seq = _kabatdict_to_seq(current_vl_kd)
+        else:
+            vh_seq = _kabatdict_to_seq(current_vh_kd)
+            vl_seq = _kabatdict_to_seq(kd2)
+
+        # Hard gate: CDRs unchanged vs mouse
+        vh_errs = verify_cdr_preservation(get_kabat_numbering(vh_seq), mouse_vh_kd, "VH")
+        vl_errs = verify_cdr_preservation(get_kabat_numbering(vl_seq), mouse_vl_kd, "VL")
+        if vh_errs or vl_errs:
+            return None
+
+        pi_val = _compute_pi(vh_seq, vl_seq)
+        if pi_val is None:
+            return None
+        return (pi_val, vh_seq, vl_seq)
+
+    # Mutation palette: prefer Q first (neutral), then E (acidic) if needed
+    palette = [("Q", 0), ("E", 1)]
+
+    used: set[Tuple[str, int]] = set()
+    for _round in range(max_mutations):
+        if current_pi <= target_pi_max:
+            break
+
+        best = None  # (new_pi, chain, pos, new_aa, new_vh, new_vl)
+
+        for chain, cands in [("VH", vh_cands), ("VL", vl_cands)]:
+            for pos in cands:
+                if (chain, pos) in used:
+                    continue
+                old_aa = (current_vh_kd if chain == "VH" else current_vl_kd).get((pos, ""))
+                if old_aa not in ("K", "R"):
+                    continue
+                for new_aa, _priority in palette:
+                    trial = _try_mut(chain, pos, new_aa)
+                    if not trial:
+                        continue
+                    new_pi, new_vh, new_vl = trial
+                    if best is None or new_pi < best[0]:
+                        best = (new_pi, chain, pos, new_aa, new_vh, new_vl)
+
+        if best is None:
+            # No safe mutation found under constraints
+            break
+
+        new_pi, chain, pos, new_aa, new_vh, new_vl = best
+        # Commit best
+        if chain == "VH":
+            current_vh_kd = get_kabat_numbering(new_vh)
+        else:
+            current_vl_kd = get_kabat_numbering(new_vl)
+        current_pi = new_pi
+        used.add((chain, pos))
+
+        muts.append({
+            "chain": chain,
+            "kabat_pos": pos,
+            "from": "K/R",
+            "to": new_aa,
+            "region": "FR（CMC）",
+            "rationale": "pI 修正：降低框架表面正电荷以改善工艺/制剂风险（不改变 CDR）",
+        })
+
+    v3_vh = _kabatdict_to_seq(current_vh_kd)
+    v3_vl = _kabatdict_to_seq(current_vl_kd)
+    final_pi = _compute_pi(v3_vh, v3_vl)
+    if final_pi is None:
+        raise RuntimeError("Unable to compute final pI.")
+    if final_pi > target_pi_max:
+        raise RuntimeError(f"v3 design failed to reach target pI≤{target_pi_max}. Got pI={final_pi:.2f}.")
+    return (v3_vh, v3_vl, muts)
+
+
+def _eval_to_payload(ev) -> Dict[str, Any]:
+    # Mirror EvaluationResult.save() payload shape without writing to disk
+    return {
+        "abenginecore_version": "1.0.0",
+        "project_name": ev.project_name,
+        "ab_type": ev.ab_type.value,
+        "overall_status": ev.overall_status,
+        "modules_run": ev.modules_run,
+        "overall_flags": ev.overall_flags,
+        "generated_at": ev.generated_at,
+        "results": ev.results,
+    }
+
+
+def _predict_pdb(vh: str, vl: str, out_pdb: Path) -> Optional[float]:
+    from ImmuneBuilder import ABodyBuilder2  # type: ignore
+    predictor = ABodyBuilder2()
+    ab = predictor.predict({"H": vh, "L": vl})
+    out_pdb.parent.mkdir(parents=True, exist_ok=True)
+    ab.save(str(out_pdb))
+    try:
+        return float(getattr(ab, "ranking_score", None))
+    except Exception:
+        return None
+
+
+def _run_eval(project_name: str, pdb: Path, ref_pdb: Path, vh: str, vl: str, use_iedb: bool) -> Dict[str, Any]:
+    from core.evaluation.evaluator import AbEvaluator, AntibodyType  # noqa: PLC0415
+    ev = AbEvaluator(
+        project_name=project_name,
+        pdb_path=str(pdb),
+        ref_pdb_path=str(ref_pdb),
+        vh_chain="H",
+        vl_chain="L",
+        vh_seq=vh,
+        vl_seq=vl,
+        ab_type=AntibodyType.HUMANIZED,
+        strict_qa=True,
+        use_iedb=use_iedb,
+    )
+    r = ev.run(modules=None)
+    return _eval_to_payload(r)
+
+
+def main() -> int:
+    ap = argparse.ArgumentParser()
+    ap.add_argument("--with-structures", action="store_true", help="rebuild mouse/v1/v2 PDBs via ImmuneBuilder")
+    ap.add_argument("--with-eval", action="store_true", help="re-run AbEvaluator v1/v2 and refresh SSOT metrics")
+    ap.add_argument("--use-iedb", action="store_true", help="enable live IEDB calls in AbEvaluator immunogenicity")
+    ap.add_argument("--design-v3", action="store_true", help="design v3 CMC (pI) optimization on top of v2, FR-only")
+    ap.add_argument("--target-pi-max", type=float, default=8.5, help="target maximum pI for v3 (default 8.5)")
+    args = ap.parse_args()
+
+    ab_id = "fxy_2c2"
+    project_dir = Path(__file__).resolve().parent
+    results_path = project_dir / f"{ab_id}_results.json"
+    p4_path = project_dir / "internal" / "phase4_backmutation_fxy_2c2.json"
+    if not results_path.exists():
+        raise FileNotFoundError(results_path)
+    if not p4_path.exists():
+        raise FileNotFoundError(p4_path)
+
+    results = _load_json(results_path)
+    seqs = results.get("sequences") or {}
+    existing_final_v = str((results.get("_meta") or {}).get("final_version") or "").strip() or None
+    existing_v3_vh = str(seqs.get("v3_VH") or "").strip()
+    existing_v3_vl = str(seqs.get("v3_VL") or "").strip()
+    mouse_vh = str(seqs.get("mouse_VH") or "").strip()
+    mouse_vl = str(seqs.get("mouse_VL") or "").strip()
+    if not mouse_vh or not mouse_vl:
+        raise ValueError("Missing mouse_VH or mouse_VL in SSOT.")
+
+    # Germline IDs are already selected in SSOT/audit
+    vh_gene = str((results.get("germline") or {}).get("VH_gene") or "IGHV5-51*01")
+    vl_gene = str((results.get("germline") or {}).get("VL_gene") or "IGKV1-39*01")
+    germ_vh_seq = _load_germline_seq(vh_gene, chain="VH")
+    germ_vl_seq = _load_germline_seq(vl_gene, chain="VL")
+
+    p4 = _load_json(p4_path)
+    bm_vh_map = {int(k): str(v) for k, v in (p4.get("bm_vh_map") or {}).items()}
+    bm_vl_map = {int(k): str(v) for k, v in (p4.get("bm_vl_map") or {}).items()}
+
+    mouse_vh_kd = get_kabat_numbering(mouse_vh)
+    mouse_vl_kd = get_kabat_numbering(mouse_vl)
+    germ_vh_kd = get_kabat_numbering(germ_vh_seq)
+    germ_vl_kd = get_kabat_numbering(germ_vl_seq)
+    if not mouse_vh_kd or not mouse_vl_kd:
+        raise RuntimeError("Mouse Kabat numbering failed; cannot proceed.")
+    if not germ_vh_kd or not germ_vl_kd:
+        raise RuntimeError("Germline Kabat numbering failed; cannot proceed.")
+
+    # Assemble v1/v2 (CDRs are defined by Kabat integer ranges; insertion codes preserved by KabatDict keys)
+    v1_vh = assemble_humanized_v("VH", mouse_vh_kd, germ_vh_kd, bm_map={}, fr4=JH4_FR4)
+    v1_vl = assemble_humanized_v("VL", mouse_vl_kd, germ_vl_kd, bm_map={}, fr4=JK4_FR4)
+    v2_vh = assemble_humanized_v("VH", mouse_vh_kd, germ_vh_kd, bm_map=bm_vh_map, fr4=JH4_FR4)
+    v2_vl = assemble_humanized_v("VL", mouse_vl_kd, germ_vl_kd, bm_map=bm_vl_map, fr4=JK4_FR4)
+
+    # v3 design (CMC / pI optimization) — always override any stale v3 in SSOT
+    if args.design_v3:
+        v3_vh, v3_vl, v2_to_v3_muts = _design_v3_pi(
+            v2_vh, v2_vl,
+            mouse_vh_kd, mouse_vl_kd,
+            target_pi_max=float(args.target_pi_max),
+            max_mutations=4,
+        )
+        # Promote v3 to final if designed successfully
+        results.setdefault("_meta", {})
+        results["_meta"]["final_version"] = "v3"
+    else:
+        # Preserve an existing v3 if present; never silently downgrade v3→v2.
+        if existing_final_v == "v3" and existing_v3_vh and existing_v3_vl:
+            v3_vh, v3_vl = existing_v3_vh, existing_v3_vl
+        else:
+            v3_vh, v3_vl = v2_vh, v2_vl
+        v2_to_v3_muts = results.get("mutations", {}).get("v2_to_v3", []) or []
+
+    # HARD GATE: 6 CDRs must match mouse exactly
+    v1_vh_errs = verify_cdr_preservation(get_kabat_numbering(v1_vh), mouse_vh_kd, "VH")
+    v1_vl_errs = verify_cdr_preservation(get_kabat_numbering(v1_vl), mouse_vl_kd, "VL")
+    v2_vh_errs = verify_cdr_preservation(get_kabat_numbering(v2_vh), mouse_vh_kd, "VH")
+    v2_vl_errs = verify_cdr_preservation(get_kabat_numbering(v2_vl), mouse_vl_kd, "VL")
+    v3_vh_errs = verify_cdr_preservation(get_kabat_numbering(v3_vh), mouse_vh_kd, "VH")
+    v3_vl_errs = verify_cdr_preservation(get_kabat_numbering(v3_vl), mouse_vl_kd, "VL")
+    errs = v1_vh_errs + v1_vl_errs + v2_vh_errs + v2_vl_errs + v3_vh_errs + v3_vl_errs
+    if errs:
+        raise RuntimeError("CDR preservation HARD GATE failed:\n  - " + "\n  - ".join(errs))
+
+    # Update SSOT sequences
+    seqs["v1_VH"] = v1_vh
+    seqs["v1_VL"] = v1_vl
+    seqs["v2_VH"] = v2_vh
+    seqs["v2_VL"] = v2_vl
+    seqs["v3_VH"] = v3_vh
+    seqs["v3_VL"] = v3_vl
+    results["sequences"] = seqs
+
+    # Update meta
+    results.setdefault("_meta", {})
+    results["_meta"]["role"] = "single_source_of_truth"
+    results["_meta"]["pipeline_standard"] = "V4.4"
+    results["_meta"]["antibody_id"] = ab_id
+    results["_meta"]["generated_at"] = datetime.now().strftime("%Y-%m-%d")
+    results["_meta"]["final_version"] = str(results["_meta"].get("final_version") or "v2")
+
+    # Update Kabat annotation blocks for FINAL version
+    final_v = results["_meta"]["final_version"]
+    final_vh = str(seqs.get(f"{final_v}_VH") or v2_vh)
+    final_vl = str(seqs.get(f"{final_v}_VL") or v2_vl)
+    results["sequence_annotation"] = {
+        "_note": "Kabat 编号 FR/CDR 切分，用于客户报告和克隆设计。",
+        "numbering_scheme": "Kabat",
+        "VH": _build_kabat_annotation(final_vh, "VH"),
+        "VL": _build_kabat_annotation(final_vl, "VL"),
+    }
+
+    # FASTA deliverable (project root + sequences/)
+    fasta_lines = [
+        f">{ab_id}_mouse|VH|parent|reference",
+        mouse_vh,
+        f">{ab_id}_mouse|VL|parent|reference",
+        mouse_vl,
+        f">{ab_id}_v1|VH|humanized|intermediate",
+        v1_vh,
+        f">{ab_id}_v1|VL|humanized|intermediate",
+        v1_vl,
+        f">{ab_id}_v2|VH|humanized|intermediate",
+        v2_vh,
+        f">{ab_id}_v2|VL|humanized|intermediate",
+        v2_vl,
+        f">{ab_id}_v3|VH|humanized|final",
+        v3_vh,
+        f">{ab_id}_v3|VL|humanized|final",
+        v3_vl,
+        "",
+    ]
+    fasta_text = "\n".join(fasta_lines)
+    (project_dir / f"{ab_id}_sequences.fasta").write_text(fasta_text, encoding="utf-8")
+    (project_dir / "sequences").mkdir(parents=True, exist_ok=True)
+    (project_dir / "sequences" / f"{ab_id}_sequences.fasta").write_text(fasta_text, encoding="utf-8")
+
+    # Optional: rebuild structures
+    structures_dir = project_dir / "structures"
+    pdb_mouse = structures_dir / f"{ab_id}_mouse.pdb"
+    pdb_v1 = structures_dir / f"{ab_id}_humanized_v1.pdb"
+    pdb_v2 = structures_dir / f"{ab_id}_humanized_v2.pdb"
+    pdb_v3 = structures_dir / f"{ab_id}_humanized_v3.pdb"
+    if args.with_structures:
+        print("[PDB] predicting mouse...")
+        _predict_pdb(mouse_vh, mouse_vl, pdb_mouse)
+        print("[PDB] predicting v1...")
+        _predict_pdb(v1_vh, v1_vl, pdb_v1)
+        print("[PDB] predicting v2...")
+        _predict_pdb(v2_vh, v2_vl, pdb_v2)
+        print("[PDB] predicting v3...")
+        _predict_pdb(v3_vh, v3_vl, pdb_v3)
+
+    # Optional: re-run evaluator and refresh SSOT fields used by report renderer
+    if args.with_eval:
+        if not pdb_mouse.exists() or not pdb_v1.exists() or not pdb_v2.exists() or not pdb_v3.exists():
+            raise FileNotFoundError("Missing PDBs; run with --with-structures first (or ensure PDBs exist).")
+
+        results.setdefault("_internal", {})
+        results["_internal"]["evaluation_v1"] = _run_eval(f"{ab_id}_v44_v1", pdb_v1, pdb_mouse, v1_vh, v1_vl, use_iedb=args.use_iedb)
+        results["_internal"]["evaluation_v2"] = _run_eval(f"{ab_id}_v44_v2", pdb_v2, pdb_mouse, v2_vh, v2_vl, use_iedb=args.use_iedb)
+        results["_internal"]["evaluation_v3"] = _run_eval(f"{ab_id}_v44_v3", pdb_v3, pdb_mouse, v3_vh, v3_vl, use_iedb=args.use_iedb)
+
+        # Update top-level PDB pointers
+        results["structure"] = {
+            "tool": "ABodyBuilder2",
+            "mouse_pdb": str(pdb_mouse).replace("/", "\\"),
+            "v1_pdb": str(pdb_v1).replace("/", "\\"),
+            "v2_pdb": str(pdb_v2).replace("/", "\\"),
+            "v3_pdb": str(pdb_v3).replace("/", "\\"),
+        }
+
+        # Summaries: developability pI + immunogenicity risk level
+        def _pI_from(ev_payload: Dict[str, Any]) -> Optional[float]:
+            dev = (ev_payload.get("results") or {}).get("developability") or {}
+            if dev.get("status") == "PASS":
+                val = dev.get("pI_fab_estimate")
+                return float(val) if isinstance(val, (int, float)) else None
+            return None
+
+        def _risk_from(ev_payload: Dict[str, Any]) -> str:
+            imm = (ev_payload.get("results") or {}).get("immunogenicity") or {}
+            r = imm.get("mhcii_risk") or imm.get("risk_level") or "—"
+            return str(r)
+
+        ev1 = results["_internal"]["evaluation_v1"]
+        ev2 = results["_internal"]["evaluation_v2"]
+        ev3 = results["_internal"]["evaluation_v3"]
+        p1 = _pI_from(ev1)
+        p2 = _pI_from(ev2)
+        p3 = _pI_from(ev3)
+        gate_min, gate_max = 5.5, 8.5
+        results["developability"] = {
+            "pI": {
+                "v1": p1,
+                "v2": p2,
+                "v3": p3,
+                "gate_min": gate_min,
+                "gate_max": gate_max,
+                "v1_pass": (gate_min <= p1 <= gate_max) if isinstance(p1, (int, float)) else False,
+                "v2_pass": (gate_min <= p2 <= gate_max) if isinstance(p2, (int, float)) else False,
+                "v3_pass": (gate_min <= p3 <= gate_max) if isinstance(p3, (int, float)) else False,
+            },
+            "liabilities": (ev3.get("results") or {}).get("cdr_scan", {}).get("liabilities", []),
+        }
+        results["immunogenicity"] = {
+            "method": "offline_heuristic" if not args.use_iedb else "iedb_api",
+            "risk_level": {"v1": _risk_from(ev1), "v2": _risk_from(ev2), "v3": _risk_from(ev3)},
+            "recommended_followup": "PBMC T 细胞增殖试验（临床前阶段）",
+        }
+
+    # Record v2→v3 mutation list for report rendering (even if empty)
+    results.setdefault("mutations", {})
+    results["mutations"].setdefault("v1_to_v2", results.get("mutations", {}).get("v1_to_v2", []))
+    results["mutations"]["v2_to_v3"] = v2_to_v3_muts
+
+    _write_json(results_path, results)
+    print(f"[OK] Updated SSOT: {results_path}")
+    print("[OK] CDR invariant satisfied for v1/v2/v3.")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
+
