{
  "_meta": {
    "standard": "VH_VL_HUMANIZATION_STANDARD_V4.5.1",
    "version": "4.5.1",
    "date": "2026-04-06",
    "scope": "vh_vl_humanization",
    "description": "VH/VL murine antibody humanization — CDR grafting, Chothia structural definitions, RMSD dual-tier, Phase 3 hard gate, confidentiality boundaries. Supersedes vh_vl_humanization_v44.json (V4.4). See docs/VH_VL_HUMANIZATION_STANDARD_V4.4.md (contains V4.5.1 appendix).",
    "locked": true,
    "governance": "docs/ABENGINECORE_GOVERNANCE.md",
    "supersedes": "vh_vl_humanization_v44.json"
  },

  "conda_environment": "anarcii",
  "python": "d:/Users/NextVivo/miniconda3/envs/anarcii/python.exe",

  "cdr_definitions": {
    "scheme": "chothia",
    "allowed_override": "kabat",
    "override_requires_client_request": true,
    "override_must_be_noted_in_report": true,
    "back_mutation_regions": "FR_only",
    "back_mutation_in_CDR_forbidden": true,
    "regions": {
      "VH": {
        "H1": [26, 32],
        "H2": [52, 56],
        "H3": [95, 102]
      },
      "VL": {
        "L1": [24, 34],
        "L2": [50, 56],
        "L3": [89, 97]
      }
    },
    "note": "Chothia numbering. Ranges are inclusive, 1-indexed Chothia positions."
  },

  "framework_selection": {
    "human_germline_database": "IMGT",
    "similarity_metric": "FR_identity_pct",
    "min_fr_identity": 0.70,
    "top_k_candidates": 5,
    "prefer_same_vgene_subgroup": true,
    "vernier_zone_check": "internal_audit_only"
  },

  "structure_modeling": {
    "tool": "ABodyBuilder2",
    "conda_env": "anarcii",
    "phase3_pdb_required": true,
    "phase3_fail_action": "HARD_ABORT",
    "phase3_min_plddt": 60.0,
    "phase3_fail_message": "V4.5.1: Phase 3  PDB (pLDDT < 60) → HARD ABORT. .",
    "fallback": null
  },

  "cdr_rmsd": {
    "stable_cdrs": ["H1", "H2", "L2", "L3"],
    "stable_threshold_angstrom": 1.5,
    "stable_fail_action": "HARD_ABORT",
    "volatile_cdrs": ["H3", "L1"],
    "volatile_threshold_angstrom": 2.5,
    "volatile_fail_action": "WARN",
    "volatile_warn_message": "AI  RMSD  — "
  },

  "vhvl_angle": {
    "compute_tool": "core/structure/affinity_energy_toolkit.py:compute_vhvl_angle",
    "warn_threshold_degrees": 10.0,
    "hard_abort_threshold_degrees": 20.0,
    "required_in_client_report": true
  },

  "canonical_class": {
    "assign_tool": "assign_canonical_class",
    "output_cdr_identity_to_known_canonical": true,
    "h3_long_threshold": 12,
    "h3_long_label": "Undefined — RMSD primary",
    "vh71_sensitivity_check": true,
    "vh71_noncanonical_action": "WARN"
  },

  "report_visibility": {
    "client_visible": [
      "cdr_rmsd_per_loop",
      "vhvl_angle_theta_mouse",
      "vhvl_angle_theta_humanized",
      "vhvl_angle_delta_theta",
      "oasis_humanness_score",
      "back_mutation_list_with_rationale",
      "germline_fr_identity_pct"
    ],
    "internal_audit_only": [
      "sasa",
      "packing_score",
      "residue_contact_map",
      "vernier_zone_analysis",
      "stability_energy_raw"
    ]
  },

  "back_mutations": {
    "max_back_mutations_per_chain": 5,
    "require_structural_justification": true,
    "allowed_reasons": [
      "CDR_contact_FR_position",
      "Vernier_zone_H/L_packing",
      "canonical_class_maintenance",
      "charge_patch_correction"
    ]
  },

  "cmc_gates": {
    "min_pi": 5.5,
    "max_pi": 9.0,
    "max_instability_index": 40.0,
    "max_gravy": 0.0,
    "min_oasis_humanness": 80.0
  },

  "compliance_rules": {
    "must_do": [
      "verify_cdr_preservation with scheme=chothia",
      "run ABodyBuilder2 Phase 3 PDB generation",
      "compute CDR RMSD for all 6 CDRs",
      "compute VH/VL angle (θ_mouse, θ_humanized, Δθ)",
      "compute OASis humanness",
      "include back_mutation_list_with_rationale in client report",
      "run CMC gate (pI, II, GRAVY, OASis)",
      "write HallucinationGuard SEQ_BACK_CHECK before finalizing output"
    ],
    "must_not_do": [
      "back-mutate any Chothia CDR position",
      "output candidate without valid Phase 3 PDB",
      "include SASA / packing / Vernier scores in client report",
      "use linear sequence index as Chothia residue number"
    ]
  },

  "versions_history": [
    {
      "version": "4.5.1",
      "date": "2026-04-06",
      "changes": [
        "Chothia CDR structural definition enforced (V4.5.1-1)",
        "CDR RMSD dual-tier: H1/H2/L2/L3 HARD GATE 1.5 Å; H3/L1 WARN (V4.5.1-2)",
        "Phase 3 no PDB → HARD ABORT (V4.5.1-3)",
        "Report confidentiality boundary: SASA/packing/Vernier = internal only (V4.5.1-4)"
      ]
    },
    {
      "version": "4.5",
      "date": "2026-04-02",
      "changes": [
        "VH/VL angle reporting (V4.5-A)",
        "Canonical class logical derivation + VH71 sensitivity (V4.5-B)"
      ]
    },
    {
      "version": "4.4",
      "date": "2026-02-18",
      "changes": [
        "Germline validation checklist",
        "5.2b canonical class determination",
        "VL BM declaration",
        "IEDB status",
        "L2 rationale requirement"
      ]
    }
  ]
}
