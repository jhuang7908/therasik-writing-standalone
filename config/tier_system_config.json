  "strategy_definitions": {
    "S1": {
      "name": "Base Humanized",
      "formula": "Tier 0 only",
      "tiers_included": ["tier_0_critical"],
      "expected_mutations": 7,
      "expected_humanization_range": [93, 96],
      "use_case": "Acute/short-term therapeutics, maximum human similarity"
    },
    "S2": {
      "name": "Safety-Optimized",
      "formula": "Tier 0 + Tier 1",
      "tiers_included": ["tier_0_critical", "tier_1_high_priority"],
      "expected_mutations": 15,
      "expected_humanization_range": [85, 90],
      "use_case": "Chronic/long-term therapeutics, balanced function and immunogenicity"
    },
    "S3": {
      "name": "Affinity-Optimized (Conservative)",
      "formula": "Tier 0 + Tier 1 + Tier 2",
      "tiers_included": ["tier_0_critical", "tier_1_high_priority", "tier_2_medium_priority"],
      "expected_mutations": 29,
      "expected_humanization_range": [73, 78],
      "use_case": "Discovery/optimization, maximum functional retention"
    }
  },
  
  "design_rules": {
    "rule_1": "S1 < S2 < S3 in back-mutation count",
    "rule_2": "S1 > S2 > S3 in humanization percentage",
    "rule_3": "CDRs are NEVER humanized (100% original)",
    "rule_4": "All Vernier anchors (28, 29, 94) must be in all strategies",
    "rule_5": "All VHH Hallmarks (37, 44, 45, 47) must be in all strategies",
    "rule_6": "S3 must have complete FR2 (16/16 positions)"
  },
  
