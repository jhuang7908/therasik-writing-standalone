  "v5_runtime": {
    "_description": "V5.0 (2026-05-16) Structure-driven dynamic Tier system. Replaces static Tier lists above as primary driver.",
    "fr_identity_cutoff": {
      "recommended": 0.65,
      "permissive": 0.60,
      "permissive_requires_audit_log": true,
      "key_position_score_floor": 0.5
    },
    "hallmark_decision_v5": {
      "_description": "Dynamic Hallmark preservation policy driven by donor CDR3 length + hydrophobicity. Aligned with V1.8.17 Stealth logic (VH->VHH conversion).",
      "rules": [
        {
          "rule_id": "FULL",
          "label": "Full camelid Hallmark preservation",
          "conditions": {"cdr3_length_min": 17, "sap_min": 0.714},
          "preserved_positions": [37, 44, 45, 47],
          "rationale": "Long CDR3 + high hydrophobicity => camelid-like FR2 needed for solubility"
        },
        {
          "rule_id": "PARTIAL",
          "label": "Partial Hallmark preservation",
          "conditions": {"cdr3_length_range": [12, 17], "pi_max": 9.0},
          "preserved_positions": [37, 44],
          "rationale": "Mid-length CDR3 + moderate charge => balanced FR2 (camelid 37/44 + human 45/47)"
        },
        {
          "rule_id": "MINIMAL",
          "label": "Minimal Hallmark preservation",
          "conditions": {"cdr3_length_max": 12, "net_basic_max": 4},
          "preserved_positions": [37],
          "rationale": "Short CDR3 + low charge => human VH3-like FR2 acceptable"
        }
      ],
      "default_when_no_rule_matches": "PARTIAL"
    },
    "dynamic_tier_formula": {
      "_description": "Per-template, per-residue Tier score using structure prediction.",
      "formula": "dynamic_tier(pos) = 0.4 * static_v4_tier_score(pos) + 0.3 * (1/SASA_rel(pos)) + 0.3 * (1/CDR_distance(pos))",
      "alpha_static_v4": 0.4,
      "beta_sasa_inv": 0.3,
      "gamma_cdr_dist_inv": 0.3,
      "thresholds": {
        "S1_S2_S3_preserve": 0.7,
        "S2_S3_preserve": 0.4,
        "humanize_freely": 0.0
      },
      "static_v4_tier_score_map": {
        "tier_0_critical": 1.0,
        "tier_1_high_priority": 0.7,
        "tier_2_medium_priority": 0.4,
        "tier_3_low_priority": 0.1,
        "unlisted": 0.0
      }
    },
    "structure_prediction": {
      "required": true,
      "predictors": ["IgFold", "ABodyBuilder2"],
      "cache_key": "sha256(template_id + humanized_seq)",
      "cache_dir": ".vhh_v5_structure_cache",
      "min_plddt_for_tier_use": 0.65,
      "fallback_when_prediction_fails": "use_static_v4_tier_only"
    },
    "deepfr_ctx_integration": {
      "ctx_guard_module": "core.humanization.ctx_guard",
      "ninemer_db_path": "config/clinical_842_9mer_db.json",
      "vote_overlapping_windows": true,
      "veto_categories": [
        "pro_introduction_backbone_disrupt",
        "pro_removal_backbone_lock",
        "gly_removal_backbone_anchor",
        "introduces_free_cys",
        "creates_n_glyc_motif",
        "strong_charge_flip",
        "global_sanity"
      ]
    },
    "no_template_fallback": {
      "_description": "When no clinical-VHH template meets cutoff and feasibility prescreen fails, use 9-aa context voting (replaces V4.0 fixed-substitution surface reshaping table).",
      "method": "deepfr_ctx_vhh_9aa_voting",
      "hard_protected_residues": ["G", "P", "C"],
      "ninemer_db": "config/clinical_842_9mer_db.json",
      "candidate_filters": [
        "reduces_local_sap_by >= 0.01",
        "no_new_ptm_motif (NG, NS, DG, DP, QG, GG, GP)",
        "no_charge_category_flip",
        "different_from_original"
      ],
      "max_iterations": 10,
      "sap_target_band_by_strategy": {
        "S1": [0.0, 0.65],
        "S2": [0.0, 0.71],
        "S3": [0.0, 0.77]
      }
    },
    "template_library": {
      "_description": "V5.0: clinical-VHH only. VH3-SAFE synthetic 90 templates DEPRECATED.",
      "primary": {
        "file": "data/vhh_clinical_39_union/vhh42_templates_cache.json",
